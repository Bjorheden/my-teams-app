# .env.example
# Copy this file to .env and adjust values for your local setup.
#   cp .env.example .env       (Linux/macOS/WSL)
#   copy .env.example .env     (Windows cmd)
#
# .env is listed in .gitignore – never commit real secrets.
# .env.example IS committed so teammates know what variables exist.

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------

# Port exposed on your host machine (http://localhost:BACKEND_PORT)
BACKEND_PORT=8000

# App environment tag – used in log output and /readyz response
ENVIRONMENT=development

# Uvicorn log level: debug | info | warning | error
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database (not used until Checkpoint 6)
# ---------------------------------------------------------------------------

# SQLite (CP6): sqlite:///./myteams.db
# Postgres (CP7): postgresql+psycopg2://myteams:myteams@db:5432/myteams
DATABASE_URL=postgresql+psycopg2://myteams:myteams@db:5432/myteams

# ---------------------------------------------------------------------------
# Postgres (CP7) – matches the values in docker-compose.yml
# ---------------------------------------------------------------------------
POSTGRES_USER=myteams
POSTGRES_PASSWORD=myteams
POSTGRES_DB=myteams
